/macos/native.framework/

# Windows
/windows/flutter/ephemeral/

# Linux
/linux/flutter/ephemeral/

# Generated files
*.g.dart
*.freezed.dart
*.tsbuildinfo
# FRB generated files are committed for CI stability
# Re-generate with: flutter_rust_bridge_codegen generate

# Swagger generated docs (docs.go MUST be tracked — server needs it for go build)
# Regenerate full docs: cd backend && swag init -g cmd/api/main.go
backend/docs/swagger.json
backend/docs/swagger.yaml

# Test files
coverage/
test/.test_coverage.dart

# Images — only allow specific directories
*.png
!**/assets/**/*.png
!**/images/**/*.png
!website/*.png

# Screenshots — local design artifacts
/screenshots/

# Tools — standalone utilities, not part of Flutter app
/tools/
!/tools/webhook-pull/

# Memory — AI/bot session data, not source code
/memory/

# yt-dlp binaries (download via script)
assets/bin/yt-dlp*
assets/bin/VERSION
!assets/bin/README.md

# Build distribution artifacts
/dist/

# Environment/secrets
.env
*.env.local
backend/.env

# Debug/temp files
context/
log*.md
/artifacts/

# Playwright MCP snapshots
.playwright-mcp/

# Backend compiled binary
/backend/api

# Claude Code session state — local-only, never committed.
# Keep shareable project agent prompts trackable; keep settings/history local.
.claude/*
!.claude/
!.claude/agents/
!.claude/agents/**
