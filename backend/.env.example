# Server
PORT=8080
# GIN_MODE: "debug" for local dev, "release" for production. Production must
# also set strong JWT_SECRET (>=32 chars), DB_SSL_MODE!=disable, ADMIN_PASSWORD,
# and STRIPE_WEBHOOK_SECRET — those checks are gated on release mode.
GIN_MODE=debug
# ENABLE_SWAGGER: opt-in flag for /swagger/* docs. Default off; flip on locally
# for API exploration. Decoupled from GIN_MODE so production can never leak
# docs by accident.
ENABLE_SWAGGER=false
# TRUSTED_PLATFORM: when running behind a known CDN, set to "cloudflare",
# "google", or "flyio" so c.ClientIP() resolves the real user IP from the
# CDN-injected header (CF-Connecting-IP, X-Appengine-Remote-Addr, Fly-Client-IP).
# Without this, every user behind the same CDN PoP shares one rate-limit
# bucket — a bot can DoS rate-limit other users sharing the PoP. Empty in dev.
TRUSTED_PLATFORM=

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=snakeloader
DB_PASSWORD=snakeloader_dev_2025
DB_NAME=snakeloader_dev
DB_SSL_MODE=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (Admin Auth)
JWT_SECRET=change-this-to-a-256-bit-secret-in-production
JWT_EXPIRY_HOURS=24

# API Key
API_KEY_EXPIRY_DAYS=365

# Admin Seed
ADMIN_EMAIL=admin@snakeloader.com
ADMIN_PASSWORD=change-this-in-production

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Gemini AI (optional - falls back to keyword-based if not set)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Stripe (required for premium payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
STRIPE_PRICE_LIFETIME_1=price_...
STRIPE_PRICE_LIFETIME_2=price_...
STRIPE_PRICE_LIFETIME_3=price_...
STRIPE_SUCCESS_URL=https://ssvid.app/payment/success
STRIPE_CANCEL_URL=https://ssvid.app/payment/cancel

# Stripe — VidCombo brand (same Stripe account, different price IDs)
STRIPE_VIDCOMBO_PRICE_MONTHLY=price_1QtOxhJykwD5LYvpyHIfyMZY
STRIPE_VIDCOMBO_PRICE_SEMIANNUAL=price_1QtOyuJykwD5LYvpgtj9EZgx
STRIPE_VIDCOMBO_PRICE_YEARLY=price_1QtP06JykwD5LYvpN1zsLtmA

# BTCPay (optional - crypto payments)
BTCPAY_SERVER_URL=
BTCPAY_STORE_ID=
BTCPAY_API_KEY=

# Telegram (optional - autonomous notifications S1+S2)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Email (optional - license expiry warnings)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@ssvid.app
